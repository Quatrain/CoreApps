# API Gateway Configuration

# The port the Gateway runs on
PORT=3000

# The URL of the upstream Node.js API (api-express)
API_UPSTREAM_URL=http://api-express:8080

# Redis connection string
REDIS_URL=redis://redis:6379

# Maximum cache size for media images (in MB). Above this size, files are streamed directly.
MAX_CACHE_SIZE_MB=5

# Maximum size (in bytes) for streaming files. Above this size, files are redirected to the storage URL.
GATEWAY_MAXSIZE=524288000

# Comma-separated list of MIME types that should bypass the gateway and be redirected directly to storage.
GATEWAY_EXCLUDED_MIMES=application/pdf,application/zip,application/x-zip-compressed

# The secret shared with the upstream API to authenticate internal gateway requests.
GATEWAY_SECRET=ty-stg-your-secret-here

# If true, the JSON API cache keys will include the user ID extracted from the JWT token.
GATEWAY_CACHE_API_BY_USER=true

# If true, the media cache keys will include the user ID extracted from the JWT token.
GATEWAY_CACHE_MEDIA_BY_USER=true

# Cache maximum age in seconds (Default: 31536000 - 1 year)
GATEWAY_CACHE_MAX_AGE=31536000
