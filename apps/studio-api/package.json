    "@quatrain/backend-sqlite": "*",
    "@quatrain/core": "*",
    "@quatrain/studio": "*",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.1",
    "typescript": "^5.1.5"
