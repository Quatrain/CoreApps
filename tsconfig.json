{
   "compilerOptions": {
      "target": "ES2022",
      "module": "NodeNext",
      "moduleResolution": "NodeNext",
      "lib": ["ES2022"],
      "strict": true,
      "esModuleInterop": true,
      "skipLibCheck": true,
      "forceConsistentCasingInFileNames": true,
      "jsx": "react-jsx",
      "declaration": true,
      "sourceMap": true,
      "declarationMap": true,
      "isolatedModules": true,
      "incremental": true,
      "outDir": "dist",
      "removeComments": true,
      "baseUrl": ".",
      "paths": {
         "@quatrain/*": ["packages/*/src/index.ts", "apps/*/src/index.ts"]
      }
   },
    "include": ["packages/ui-list/src/index.ts"],
    "exclude": ["node_modules", "**/dist", "**/lib"]
}
